#(c) logit

import math

def logit(x:float, beta0:float, beta1:float) -> float:
    """ 
    compute logistic probability
    x: explanatory variable
    beta0: intercept
    beta1: slope coefficient
    Prob = (e^(beta0 + xbeta1)) / (1 + e^(beta0 + xbeta1))
    """
    exponent = beta0 + x * beta1
    exp_value = math.exp(exponent)
    return exp_value / (1 + exp_value)

#(d) logistic regression

def logit_like(yi:int, xi:float, beta0:float, beta1:float) -> float:
    """ 
    return log-likelihood for one observation
    """
    p = logit(xi, beta0, beta1)
    
    if yi == 1:
        return math.log(p)
    if yi == 0:
        return math.log(1-p)
    else:
        print("Error: yi must be 0 to 1")
        return None
