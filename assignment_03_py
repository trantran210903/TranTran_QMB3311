#(a) CESutitily

def CESutility_valid(x:float, y:float, r:float) -> float:
    """ 
    x, y: quantity of two goods
    r: subtitution parameters
    utility function u(x,y) = (x^r + y^r)^(1/r)
    condition
    x >= 0
    y >= 0
    r > 0
    """
    if x < 0:
        print("Error: x must be non-negative.")
        return None
    if y < 0:
        print("Error: y must be non-negative")
        return None
    if r <= 0:
        print("Error: r must be positive")
        return None
    return (x ** r + y ** r) ** (1/r)

